---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { cta } from '../data/site';
import { rtsPhases } from '../data/content';

const audience = [
  { icon: 'Dumbbell', title: 'Athletinnen & Athleten', text: 'Zurück in Training und Wettkampf - mit der Belastbarkeit, die der Sport verlangt.' },
  { icon: 'Activity', title: 'Aktive Menschen', text: 'Laufen, Kraftsport, Rad, Mannschaftssport - zurück zu dem, was Ihnen Spass macht.' },
  { icon: 'HeartPulse', title: 'Nach Verletzung oder OP', text: 'Strukturierter Wiederaufbau, wenn die akute Phase vorbei ist und es weitergehen soll.' },
];
---
<Layout title="Return to Sport - Sport-Reha in Berlin-Mitte | Backroom Physio" current="/return-to-sport">
  <PageHero
    crumb="Return to Sport"
    eyebrow="Return to Sport"
    title="Schmerzfrei ist der Anfang. <span class='text-green-ink'>Belastbar</span> ist das Ziel."
    subtitle="Return to Sport ist die Haltung dieser Praxis: Reha, die nicht beim Schmerz endet, sondern dort, wo Sie wieder loslegen - im Sport, im Training, in Bewegung."
    primary={{ href: cta.book.href, label: 'Termin über Doctolib', external: true }}
    secondary={{ href: '/leistungen', label: 'Alle Leistungen' }}
  />

  <!-- Philosophie + Bild -->
  <section class="py-20 md:py-28 bg-paper">
    <div class="container-px">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div data-reveal>
          <span class="eyebrow mb-5">Die Idee</span>
          <h2 class="display-2 text-balance mb-6">Reha, die dich zurückbringt.</h2>
          <p class="lede mb-4">
            Viele Behandlungen enden, sobald der Schmerz nachlässt. Damit fehlt aber genau
            der Teil, der über die Rückkehr entscheidet: wieder belastbar werden.
          </p>
          <p class="text-muted leading-relaxed mb-4">
            Return to Sport schliesst diese Lücke. Wir arbeiten aktiv und schrittweise an
            Kraft, Stabilität und Belastbarkeit - so weit, wie es Ihr Ziel verlangt. Ob das
            der nächste Wettkampf ist oder der Weg zurück in einen aktiven Alltag.
          </p>
          <p class="text-muted leading-relaxed">
            Das eng verwandte <strong>Return to Activity</strong> meint dasselbe Prinzip für
            den Alltag: zurück in Bewegung, die zählt - ohne dass Wettkampf das Ziel sein muss.
          </p>
        </div>
        <div data-reveal style="--rd:120ms">
          <div class="relative overflow-hidden rounded-[22px] border border-line aspect-[4/5] lg:min-h-[480px]" style="box-shadow: var(--shadow-photo); background: rgb(var(--rgb-mist));">
            <img src="/images/return-to-sport.webp" alt="Athlet mit Sportprothese beim Lauftraining" width="720" height="900" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3-Phasen (Dark) -->
  <section class="section-dark glow-green relative overflow-hidden py-20 md:py-28">
    <div class="container-px relative">
      <div class="max-w-2xl mb-14" data-reveal>
        <span class="eyebrow eyebrow-on-dark mb-5">Wie es abläuft</span>
        <h2 class="display-2 text-white text-balance mb-5">Der Weg zurück, Etappe für Etappe.</h2>
        <p class="text-white/70 text-lg leading-relaxed">
          Das Prinzip ist immer dasselbe, der Plan ist individuell. Wo Sie starten und wie
          schnell es geht, klären wir gemeinsam beim ersten Termin.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {rtsPhases.map((ph, i) => (
          <div class="card-dark p-8" data-reveal style={`--rd:${i * 90}ms`}>
            <span class="font-display text-green-bright text-sm font-semibold tracking-widest">{ph.step}</span>
            <h3 class="font-display text-white text-xl font-semibold mt-3 mb-3">{ph.title}</h3>
            <p class="text-white/65 leading-relaxed">{ph.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Für wen -->
  <section class="py-20 md:py-28 bg-paper">
    <div class="container-px">
      <div class="max-w-2xl mb-12" data-reveal>
        <span class="eyebrow mb-5">Für wen</span>
        <h2 class="display-2 text-balance">Wenn das Ziel mehr ist als „kein Schmerz".</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
        {audience.map((a, i) => (
          <div class="card p-7 md:p-8" data-reveal style={`--rd:${i * 90}ms`}>
            <span class="icon-chip mb-6"><Icon name={a.icon} size={24} strokeWidth={1.75} /></span>
            <h3 class="font-display text-xl font-semibold text-ink mb-2.5">{a.title}</h3>
            <p class="text-muted leading-relaxed">{a.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title="Wohin soll die Reise zurückgehen?" text="Erzählen Sie uns Ihr Ziel - welcher Sport, welche Belastung, welcher Alltag. Den Rest planen wir gemeinsam. Buchen Sie Ihren Termin direkt online." />
</Layout>
