---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import MapBlock from '../components/MapBlock.astro';
import Icon from '../components/Icon.astro';
import { site, cta, addressOneLine } from '../data/site';
---
<Layout title="Kontakt & Anfahrt - Berlin-Mitte | Backroom Physio" current="/kontakt">
  <PageHero
    crumb="Kontakt"
    eyebrow="Kontakt & Termin"
    title="Kurzer Weg zum <span class='text-green-ink'>ersten Termin</span>."
    subtitle="Buchen Sie direkt online über Doctolib oder melden Sie sich telefonisch. Wir sind in Berlin-Mitte, gut erreichbar."
    primary={{ href: cta.book.href, label: 'Termin über Doctolib', external: true }}
  />

  <section class="py-16 md:py-24 bg-paper">
    <div class="container-px">
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-10 items-stretch">
        <!-- Tiles -->
        <div class="grid sm:grid-cols-2 gap-4 content-start">
          <a href={cta.book.href} target="_blank" rel="noopener" class="card card-hover p-6 sm:col-span-2 flex items-center gap-5 group">
            <span class="icon-chip flex-none"><Icon name="CalendarCheck" size={24} strokeWidth={1.8} /></span>
            <span class="flex-1">
              <span class="block font-display text-lg font-semibold text-ink">Termin über Doctolib</span>
              <span class="block text-muted text-sm">Online buchen - jederzeit, ohne Wartemusik</span>
            </span>
            <Icon name="ArrowUpRight" size={20} strokeWidth={2} class="text-green-deep transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
          <a href={cta.phone.href} class="card card-hover p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Phone" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Telefon</span><span class="block font-display text-base font-semibold text-ink mt-0.5">{site.phoneDisplay}</span></span>
          </a>
          <a href={`mailto:${site.email}`} class="card card-hover p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Mail" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">E-Mail</span><span class="block font-display text-[0.95rem] font-semibold text-ink mt-0.5 break-all">{site.email}</span></span>
          </a>
          <a href={site.instagram} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3 group">
            <span class="icon-chip"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Instagram</span><span class="block font-display text-base font-semibold text-ink mt-0.5">{site.instagramHandle}</span></span>
          </a>
          <div class="card p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Clock" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Termine</span><span class="block text-ink font-medium mt-0.5 text-[0.95rem]">Nach Vereinbarung</span><span class="block text-muted text-sm mt-1">am besten über Doctolib</span></span>
          </div>
          <div class="card p-6 sm:col-span-2 flex items-start gap-4">
            <span class="icon-chip flex-none"><Icon name="MapPin" size={21} strokeWidth={1.9} /></span>
            <div class="flex-1">
              <span class="block text-muted-light text-xs uppercase tracking-wider font-display">Standort</span>
              <span class="block text-ink font-medium mt-0.5">{site.name}</span>
              <span class="block text-muted mt-0.5">{addressOneLine} · {site.address.district}</span>
            </div>
            <a href={site.maps.url} target="_blank" rel="noopener" class="btn btn-ghost btn-sm flex-none self-center"><Icon name="Navigation" size={14} strokeWidth={2.2} />Route</a>
          </div>
        </div>
        <!-- Map -->
        <MapBlock class="min-h-[420px] lg:min-h-full" />
      </div>
    </div>
  </section>
</Layout>
