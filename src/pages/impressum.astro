---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
// Impressum. Die Altseite hatte keines; Angaben auf Basis der bekannten Praxisdaten
// (Inhaber Sergey Bogdanov, Adresse, Kontakt) + Berliner Standard-Heilberufsangaben.
---
<Layout title={`Impressum - ${site.name}`} noindex={true} current="/impressum">
  <section class="pt-28 pb-12 md:pt-36 md:pb-16 border-b border-line" style="background: rgb(var(--rgb-surface));">
    <div class="container-narrow">
      <span class="eyebrow mb-4">Rechtliches</span>
      <h1 class="display-2">Impressum</h1>
    </div>
  </section>
  <section class="py-14 md:py-20 bg-paper">
    <div class="container-narrow">
      <div class="legal-prose">
        <h2>Angaben gemäß § 5 DDG (TMG)</h2>
        <p>
          Sergey Bogdanov<br />
          Backroom Physio Berlin (Einzelunternehmen)<br />
          {site.address.street}<br />
          {site.address.postcode} {site.address.city}
        </p>

        <h2>Kontakt</h2>
        <p>
          Telefon: {site.phoneDisplay}<br />
          E-Mail: <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>

        <h2>Berufsbezeichnung und berufsrechtliche Regelungen</h2>
        <p>
          Berufsbezeichnung: Physiotherapeut/in (verliehen in der Bundesrepublik Deutschland)<br />
          Verliehen durch: Landesamt für Gesundheit und Soziales Berlin (LAGeSo)<br />
          Es gelten das Masseur- und Physiotherapeutengesetz (MPhG) sowie die Ausbildungs- und
          Prüfungsverordnung für Physiotherapeuten (PhysTh-APrV), einsehbar unter
          <a href="https://www.gesetze-im-internet.de" target="_blank" rel="noopener">www.gesetze-im-internet.de</a>.
        </p>

        <h2>Aufsichtsbehörde</h2>
        <p>Landesamt für Gesundheit und Soziales Berlin (LAGeSo), Turmstraße 21, 10559 Berlin.</p>

        <h2>Redaktionell verantwortlich</h2>
        <p>Sergey Bogdanov<br />Anschrift wie oben</p>

        <h2>EU-Streitschlichtung</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener">https://ec.europa.eu/consumers/odr/</a>.
          Unsere E-Mail-Adresse finden Sie oben.
        </p>

        <h2>Verbraucherstreitbeilegung</h2>
        <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>

        <h2>Bildnachweis</h2>
        <p>Logo, Team- und Praxisfotos: Backroom Physio Berlin. Weitere Bilder (z. B. Hero, Return to Sport): Pexels (lizenzfrei).</p>
      </div>
    </div>
  </section>
</Layout>
