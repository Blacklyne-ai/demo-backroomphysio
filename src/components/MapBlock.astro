---
// Google Maps - lädt automatisch (Kundenwunsch). Lazy eingebettet.
// Hinweis: Auto-Load überträgt direkt Daten an Google (DSGVO siehe JUDGEMENT_CALLS).
import { site, addressOneLine } from '../data/site';
import { getLang } from '../i18n/ui';
import { useT } from '../i18n/t';
import Icon from './Icon.astro';
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const t = useT(getLang(Astro.url));
---
<div class={`relative overflow-hidden rounded-[20px] border border-line ${className}`} style="background: rgb(var(--rgb-surface));">
  <iframe
    src={site.maps.embed}
    title={`Karte - ${site.name}`}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="w-full h-full block"
    style="min-height: 420px; border: 0;"
  ></iframe>
  <a href={site.maps.url} target="_blank" rel="noopener" class="absolute bottom-4 left-4 btn btn-primary btn-sm shadow-lg z-10">
    <Icon name="Navigation" size={14} strokeWidth={2.2} /> {t.map.directionsBtn}
  </a>
</div>
