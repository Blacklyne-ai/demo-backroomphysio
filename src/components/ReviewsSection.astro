---
// Bewertungs-Sektion. Aggregat-Panel (echt, aus site.google) + Live-Einzelreviews,
// sobald reviews.json via Google Places API befuellt ist (scripts/fetch-reviews.mjs).
// NIE erfundene Reviews: ohne API-Daten nur Panel + Link auf die echten Google-Reviews.
import { site } from '../data/site';
import Icon from './Icon.astro';
import ReviewBadge from './ReviewBadge.astro';
import reviews from '../data/reviews.json';
import { reviewHighlights } from '../data/content';

const rating = reviews.rating > 0 ? reviews.rating : site.google.rating;
const count = reviews.total > 0 ? reviews.total : site.google.reviewsCount;
const url = reviews.url || site.google.reviewsUrl;
const ratingStr = rating.toFixed(1).replace('.', ',');
const list = (reviews.reviews || []).filter((r) => r && r.text);
const stars = [0, 1, 2, 3, 4];
const starPct = (r: number) => Math.max(0, Math.min(100, (r / 5) * 100));
if (rating <= 0) return null; // ohne echtes Rating: Sektion gar nicht zeigen
---
<section class="py-20 md:py-28" style="background: rgb(var(--rgb-surface));">
  <div class="container-px">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <!-- Aggregat-Panel -->
      <div class="lg:col-span-5" data-reveal>
        <span class="eyebrow mb-5">Stimmen</span>
        <h2 class="display-2 text-balance mb-6">Bewertet auf <span class="text-green-ink">Google</span>.</h2>
        <div class="flex items-end gap-4 mb-3">
          <span class="font-display font-semibold text-ink leading-none" style="font-size: clamp(3rem,7vw,4.5rem);">{ratingStr}</span>
          <span class="pb-2">
            <span class="rs-stars" aria-hidden="true">
              <span class="rs-row rs-bg">{stars.map(() => (<svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>))}</span>
              <span class="rs-row rs-fg" style={`width:${starPct(rating)}%`}>{stars.map(() => (<svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>))}</span>
            </span>
            <span class="block text-muted text-sm mt-1.5">{count} Google-Bewertungen</span>
          </span>
        </div>
        <p class="text-muted leading-relaxed mb-7 max-w-md">
          Was Patient:innen über Backroom Physio sagen - direkt auf Google, ungefiltert.
        </p>
        <a href={url} target="_blank" rel="noopener" class="btn btn-primary">
          Alle Bewertungen auf Google lesen<Icon name="ArrowUpRight" size={16} strokeWidth={2.2} />
        </a>
      </div>

      <!-- Einzelreviews (nur wenn via API vorhanden) -->
      <div class="lg:col-span-7">
        {list.length > 0 ? (
          <div class="flex flex-col gap-4">
            {list.slice(0, 3).map((r, i) => (
              <figure class="card p-6 flex flex-col" data-reveal style={`--rd:${i * 80}ms`}>
                <span class="rs-stars rs-sm mb-3" aria-hidden="true">
                  <span class="rs-row rs-bg">{stars.map(() => (<svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>))}</span>
                  <span class="rs-row rs-fg" style={`width:${starPct(r.rating || 5)}%`}>{stars.map(() => (<svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>))}</span>
                </span>
                <blockquote class="text-ink-soft leading-relaxed text-[0.97rem] flex-1">{r.text}</blockquote>
                <figcaption class="flex items-center gap-2 mt-4 pt-4 border-t border-line text-sm">
                  <span class="font-semibold text-ink">{r.author}</span>
                  {r.time && <span class="text-muted-light">· {r.time}</span>}
                  <span class="ml-auto text-muted-light text-xs inline-flex items-center gap-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M23 12.26c0-.82-.07-1.6-.21-2.36H12v4.47h6.19a5.3 5.3 0 0 1-2.3 3.48v2.9h3.72c2.18-2 3.39-4.96 3.39-8.49z"/><path fill="#34A853" d="M12 24c3.1 0 5.7-1.03 7.6-2.79l-3.72-2.9c-1.03.7-2.35 1.1-3.88 1.1-2.98 0-5.5-2.01-6.4-4.72H1.76v2.99A12 12 0 0 0 12 24z"/><path fill="#FBBC05" d="M5.6 14.69a7.2 7.2 0 0 1 0-4.62V7.08H1.76a12 12 0 0 0 0 10.6z"/><path fill="#EA4335" d="M12 4.77c1.68 0 3.2.58 4.39 1.72l3.29-3.29C17.7 1.2 15.1 0 12 0A12 12 0 0 0 1.76 7.08l3.84 2.99C6.5 7.36 9.02 4.77 12 4.77z"/></svg>
                    Google
                  </span>
                </figcaption>
              </figure>
            ))}
          </div>
        ) : (
          <div class="card p-8 md:p-10 flex flex-col items-start gap-5" data-reveal>
            <span class="icon-chip"><Icon name="Quote" size={24} strokeWidth={1.75} /></span>
            <p class="text-ink-soft leading-relaxed text-lg max-w-lg">
              Echte Patient:innen-Stimmen, ungefiltert auf Google. Lesen Sie selbst,
              was andere über Backroom Physio sagen.
            </p>
            <ReviewBadge variant="light" class="mt-1" />
          </div>
        )}
      </div>
    </div>

    <!-- Aus den Reviews destillierte, belegte Themen -->
    <div class="mt-12 pt-10 border-t border-line" data-reveal>
      <p class="text-muted-light text-xs uppercase tracking-widest font-display mb-5">Immer wieder in den Bewertungen genannt</p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {reviewHighlights.map((h) => (
          <div class="flex items-center gap-3">
            <span class="icon-chip flex-none w-10 h-10"><Icon name={h.icon} size={20} strokeWidth={1.9} /></span>
            <span class="text-ink font-medium text-[0.95rem] leading-snug">{h.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .rs-stars { position: relative; display: inline-block; line-height: 0; }
  .rs-row { display: inline-flex; gap: 2px; }
  .rs-row svg { width: 22px; height: 22px; display: block; }
  .rs-sm .rs-row svg { width: 16px; height: 16px; }
  .rs-bg svg { fill: rgb(var(--rgb-steel) / 0.4); }
  .rs-fg { position: absolute; inset: 0; overflow: hidden; white-space: nowrap; }
  .rs-fg svg { fill: #FBBC04; }
</style>
