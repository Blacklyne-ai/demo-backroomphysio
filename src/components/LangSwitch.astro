---
// DE/EN/RU-Sprachschalter — echte Routen. Verlinkt die gleiche Seite in der anderen
// Sprache; existiert sie dort nicht (z. B. Recht nur DE), führt er auf die Startseite.
import { locales, languages, getLang, basePath, localizedPath, translatedRoutes } from '../i18n/ui';
interface Props { variant?: 'light' | 'dark' }
const { variant = 'light' } = Astro.props;
const lang = getLang(Astro.url);
const base = basePath(Astro.url);
const targetFor = (loc: typeof locales[number]) =>
  translatedRoutes.includes(base) ? localizedPath(base, loc) : localizedPath('', loc);
---
<div class={`lang-pill ${variant === 'dark' ? 'lang-pill-dark' : ''}`} role="group" aria-label="Sprache wählen">
  {locales.map((loc) => (
    <a
      class="lang-opt"
      href={targetFor(loc)}
      hreflang={loc}
      aria-current={loc === lang ? 'true' : undefined}
      title={languages[loc]}
    >{loc.toUpperCase()}</a>
  ))}
</div>
