---
import { site, nav, addressOneLine, cta } from '../data/site';
import { getLang, localizedPath } from '../i18n/ui';
import { useT } from '../i18n/t';
import Icon from './Icon.astro';
import LangSwitch from './LangSwitch.astro';
const lang = getLang(Astro.url);
const t = useT(lang);
const year = 2026;
// Recht nur DE → immer auf die deutschen Rechtsseiten verlinken
const legalNav = [
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
];
---
<footer class="section-dark relative overflow-hidden" role="contentinfo" style="background: rgb(var(--rgb-dark-deep));">
  <div class="container-px relative pt-16 md:pt-20 pb-24 sm:pb-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-10 pb-12 border-b border-white/10">
      <div class="lg:col-span-5">
        <a href={localizedPath('', lang)} aria-label="Backroom Physio Berlin - Start" class="inline-flex items-center gap-3">
          <img src="/logo.png" alt="Backroom Physio Berlin" width="605" height="503" class="h-9 w-auto" loading="lazy" />
          <span class="font-display font-semibold text-xl text-white tracking-tight">Backroom Physio</span>
        </a>
        <p class="text-white/55 text-[0.95rem] leading-relaxed mt-6 max-w-sm">{t.common.tagline}</p>
        <div class="flex items-center gap-3 mt-7">
          <a href={site.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <span class="text-white/45 text-sm">{site.instagramHandle}</span>
        </div>
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-white text-[0.74rem] font-semibold uppercase tracking-[0.16em] mb-5 font-display">{t.common.navigation}</h3>
        <ul class="space-y-2.5 text-[0.92rem]">
          {nav.map((l) => (<li><a href={localizedPath(l.href, lang)} class="text-white/60 hover:text-white transition">{t.nav[l.key]}</a></li>))}
        </ul>
      </div>

      <div class="lg:col-span-4">
        <h3 class="text-white text-[0.74rem] font-semibold uppercase tracking-[0.16em] mb-5 font-display">{t.nav.kontakt}</h3>
        <ul class="space-y-3.5 text-[0.92rem] text-white/60">
          <li class="flex items-start gap-2.5">
            <Icon name="MapPin" size={15} strokeWidth={2} class="text-green-bright mt-0.5 flex-none" />
            <span>{site.address.street}<br />{site.address.postcode} {site.address.city} · {site.address.district}</span>
          </li>
          <li><a href={cta.phone.href} class="inline-flex items-center gap-2.5 hover:text-white transition"><Icon name="Phone" size={15} strokeWidth={2} class="text-green-bright" />{site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`} class="inline-flex items-center gap-2.5 hover:text-white transition break-all"><Icon name="Mail" size={15} strokeWidth={2} class="text-green-bright" />{site.email}</a></li>
          <li><a href={cta.book.href} target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 hover:text-white transition"><Icon name="CalendarCheck" size={15} strokeWidth={2} class="text-green-bright" />{t.common.bookDoctolib}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-7 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
      <p class="text-white/50 text-[0.82rem]">© {year} {site.name} · {addressOneLine}</p>
      <div class="flex items-center gap-5 text-[0.85rem]">
        <LangSwitch variant="dark" />
        {legalNav.map((l) => (<a href={l.href} class="text-white/60 hover:text-white transition">{l.label}</a>))}
      </div>
    </div>
  </div>
</footer>

<style>
  .social-ico { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 999px; color: rgba(255,255,255,0.78); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); transition: all 0.25s ease; }
  .social-ico:hover { color: #fff; background: rgba(31,199,119,0.18); border-color: rgba(31,199,119,0.5); transform: translateY(-2px); }
</style>
