---
// Schema.org — eine Physiotherapie-Praxis in Berlin-Mitte. NUR belegte Fakten
// (Scrape). KEIN erfundenes Rating, KEINE erfundenen Öffnungszeiten (Operator-TODO).
import { site, addressOneLine } from '../data/site';
import { getLang } from '../i18n/ui';
import { useT } from '../i18n/t';
interface Props { schema?: object | object[] | null }
const { schema = null } = Astro.props;
const t = useT(getLang(Astro.url));

const place = {
  '@type': ['MedicalBusiness', 'Physiotherapy'],
  '@id': site.url + '/#practice',
  name: site.name,
  description: site.metaDescription,
  url: site.url,
  telephone: site.phoneIntl,
  email: site.email,
  image: new URL('/images/og.jpg', site.url).toString(),
  logo: new URL('/logo.png', site.url).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postcode,
    addressLocality: site.address.city,
    addressRegion: 'Berlin',
    addressCountry: 'DE',
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  hasMap: site.maps.url,
  areaServed: ['Berlin', 'Berlin-Mitte'],
  availableLanguage: ['German', 'English', 'Russian'],
  medicalSpecialty: ['Physiotherapy', 'SportsMedicine'],
  sameAs: [site.instagram],
  potentialAction: {
    '@type': 'ReserveAction',
    name: t.common.bookDoctolib,
    target: site.doctolib,
  },
};

const extra = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const json = JSON.stringify({ '@context': 'https://schema.org', '@graph': [place, ...extra] });
---
<script type="application/ld+json" set:html={json} />
