---
// Subpage-Hero — type-led auf Surface. Breadcrumb + Eyebrow + H1 + Intro + optionales Foto.
import Icon from './Icon.astro';
import { getLang, localizedPath } from '../i18n/ui';
import { useT } from '../i18n/t';
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumb?: string;
  image?: string;
  imageAlt?: string;
  primary?: { href: string; label: string; external?: boolean };
  secondary?: { href: string; label: string };
}
const { eyebrow, title, subtitle, crumb, image, imageAlt = '', primary, secondary } = Astro.props;
const lang = getLang(Astro.url);
const t = useT(lang);
---
<section class="relative overflow-hidden pt-28 pb-14 md:pt-36 md:pb-20 border-b border-line" style="background: rgb(var(--rgb-surface));">
  <div class="container-px relative">
    <nav class="flex items-center gap-2 text-[0.8rem] text-muted mb-7" aria-label="Breadcrumb">
      <a href={localizedPath('', lang)} class="hover:text-green-ink transition">{t.pagehero.home}</a>
      <Icon name="ChevronRight" size={13} strokeWidth={2.2} />
      <span class="text-ink/70 font-medium">{crumb ?? ''}</span>
    </nav>
    <div class={`grid ${image ? 'lg:grid-cols-12 gap-10 lg:gap-16 items-center' : ''}`}>
      <div class={image ? 'lg:col-span-7' : 'max-w-3xl'} data-reveal>
        {eyebrow && <span class="eyebrow mb-5">{eyebrow}</span>}
        <h1 class="display-1 text-balance" set:html={title} />
        {subtitle && <p class="lede mt-6 max-w-2xl">{subtitle}</p>}
        {(primary || secondary) && (
          <div class="flex flex-col sm:flex-row gap-3 mt-9">
            {primary && <a href={primary.href} target={primary.external ? '_blank' : undefined} rel={primary.external ? 'noopener' : undefined} class="btn btn-primary btn-lg">{primary.label}<Icon name={primary.external ? 'ArrowUpRight' : 'ArrowRight'} size={16} strokeWidth={2.2} /></a>}
            {secondary && <a href={secondary.href} class="btn btn-ghost btn-lg">{secondary.label}</a>}
          </div>
        )}
      </div>
      {image && (
        <div class="lg:col-span-5" data-reveal style="--rd:120ms">
          <div class="relative overflow-hidden rounded-[20px] border border-line aspect-[4/3]" style="box-shadow: var(--shadow-photo); background: rgb(var(--rgb-mist));">
            <img src={image} alt={imageAlt} width="640" height="480" loading="eager" class="w-full h-full object-cover" />
          </div>
        </div>
      )}
    </div>
  </div>
</section>
