---
// Finales CTA-Band - hell, Glas-Optik, grüner Akzent. Doctolib = Primär-CTA.
import Icon from './Icon.astro';
import { cta } from '../data/site';
import { getLang } from '../i18n/ui';
import { useT } from '../i18n/t';
const lang = getLang(Astro.url);
const t = useT(lang);
interface Props { title?: string; text?: string }
const { title = t.cta.title, text = t.cta.text } = Astro.props;
---
<section class="py-16 md:py-24">
  <div class="container-px">
    <div class="relative overflow-hidden rounded-[28px] border border-white/70 glass-tint px-7 py-12 md:px-14 md:py-16" style="box-shadow: var(--shadow-lift);" data-reveal>
      <div class="absolute -right-16 -top-16 w-72 h-72 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgb(31 199 119 / 0.25), transparent 70%);" aria-hidden="true"></div>
      <div class="relative max-w-2xl">
        <span class="eyebrow mb-6">{t.cta.eyebrow}</span>
        <h2 class="display-2 text-balance mb-5">{title}</h2>
        <p class="text-lg md:text-xl text-muted leading-relaxed mb-9">{text}</p>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3">
          <a href={cta.book.href} target="_blank" rel="noopener" class="btn btn-primary btn-lg">{t.common.bookDoctolib}<Icon name="ArrowUpRight" size={17} strokeWidth={2.2} /></a>
          <a href={cta.phone.href} class="btn btn-ghost btn-lg"><Icon name="Phone" size={17} strokeWidth={2.2} />{cta.phone.label}</a>
        </div>
      </div>
    </div>
  </div>
</section>
