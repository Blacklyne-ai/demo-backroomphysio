---
// DSGVO-Hinweis. Texte aus i18n. Datenschutz-Seite nur DE.
import { getLang } from '../i18n/ui';
import { useT } from '../i18n/t';
const t = useT(getLang(Astro.url));
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[60] p-3 md:p-4 translate-y-full transition-transform duration-500" style="will-change: transform;">
  <div class="container-px flex justify-start">
    <div class="rounded-2xl px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 max-w-xl" style="background: rgba(11,14,16,0.97); border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 24px 60px -20px rgba(0,0,0,0.6); backdrop-filter: blur(14px);">
      <p class="text-white/75 text-[0.84rem] leading-relaxed">
        {t.cookie.text} <a href="/datenschutz" class="text-white underline underline-offset-2">{t.cookie.privacy}</a>.
      </p>
      <button id="cookie-ok" class="btn btn-on-dark btn-sm flex-shrink-0 self-start sm:self-auto">{t.cookie.ok}</button>
    </div>
  </div>
</div>
<script>
  const KEY = 'backroom-cookie-notice';
  document.addEventListener('astro:page-load', () => {
    const banner = document.getElementById('cookie-banner');
    const stored = (() => { try { return localStorage.getItem(KEY); } catch { return 'dismissed'; } })();
    if (!stored && banner) setTimeout(() => (banner.style.transform = 'translateY(0)'), 1200);
    document.getElementById('cookie-ok')?.addEventListener('click', () => {
      try { localStorage.setItem(KEY, 'ok'); } catch {}
      if (banner) banner.style.transform = 'translateY(150%)';
    });
  });
</script>
