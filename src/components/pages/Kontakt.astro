---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../PageHero.astro';
import MapBlock from '../MapBlock.astro';
import ReviewBadge from '../ReviewBadge.astro';
import Icon from '../Icon.astro';
import { site, cta, addressOneLine } from '../../data/site';
import { getLang } from '../../i18n/ui';
import { useT } from '../../i18n/t';
const lang = getLang(Astro.url);
const t = useT(lang);
const k = t.kontakt;
---
<Layout title={`${t.nav.kontakt} · Backroom Physio Berlin`} description={k.heroSub} current="/kontakt">
  <PageHero crumb={t.nav.kontakt} eyebrow={t.home.kontaktEyebrow} title={k.heroTitle} subtitle={k.heroSub}
    primary={{ href: cta.book.href, label: t.common.bookDoctolib, external: true }} />

  <section class="py-16 md:py-24 bg-paper">
    <div class="container-px">
      <div class="mb-8"><ReviewBadge variant="light" /></div>
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-10 items-stretch">
        <div class="grid sm:grid-cols-2 gap-4 content-start">
          <a href={cta.book.href} target="_blank" rel="noopener" class="card card-hover p-6 sm:col-span-2 flex items-center gap-5 group">
            <span class="icon-chip flex-none"><Icon name="CalendarCheck" size={24} strokeWidth={1.8} /></span>
            <span class="flex-1">
              <span class="block font-display text-lg font-semibold text-ink">{t.home.tileDoctolib}</span>
              <span class="block text-muted text-sm">{t.home.tileDoctolibSub}</span>
            </span>
            <Icon name="ArrowUpRight" size={20} strokeWidth={2} class="text-green-deep transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
          <a href={cta.phone.href} class="card card-hover p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Phone" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{k.tilePhone}</span><span class="block font-display text-base font-semibold text-ink mt-0.5">{site.phoneDisplay}</span></span>
          </a>
          <a href={`mailto:${site.email}`} class="card card-hover p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Mail" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{k.tileMail}</span><span class="block font-display text-[0.95rem] font-semibold text-ink mt-0.5 break-all">{site.email}</span></span>
          </a>
          <a href={site.instagram} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3 group">
            <span class="icon-chip"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{k.tileInstagram}</span><span class="block font-display text-base font-semibold text-ink mt-0.5">{site.instagramHandle}</span></span>
          </a>
          <div class="card p-6 flex flex-col gap-3">
            <span class="icon-chip"><Icon name="Clock" size={21} strokeWidth={1.9} /></span>
            <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{k.appts}</span><span class="block text-ink font-medium mt-0.5 text-[0.95rem]">{k.apptsValue}</span><span class="block text-muted text-sm mt-1">{k.apptsSub}</span></span>
          </div>
          <div class="card p-6 sm:col-span-2 flex items-start gap-4">
            <span class="icon-chip flex-none"><Icon name="MapPin" size={21} strokeWidth={1.9} /></span>
            <div class="flex-1">
              <span class="block text-muted-light text-xs uppercase tracking-wider font-display">{k.tileLocation}</span>
              <span class="block text-ink font-medium mt-0.5">{site.name}</span>
              <span class="block text-muted mt-0.5">{addressOneLine} · {site.address.district}</span>
            </div>
            <a href={site.maps.url} target="_blank" rel="noopener" class="btn btn-ghost btn-sm flex-none self-center"><Icon name="Navigation" size={14} strokeWidth={2.2} />{t.common.directions}</a>
          </div>
        </div>
        <MapBlock class="min-h-[420px] lg:min-h-full" />
      </div>
    </div>
  </section>
</Layout>
