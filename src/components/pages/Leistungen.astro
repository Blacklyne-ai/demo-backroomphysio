---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../PageHero.astro';
import CtaBand from '../CtaBand.astro';
import Icon from '../Icon.astro';
import { cta } from '../../data/site';
import { getLang, localizedPath } from '../../i18n/ui';
import { useT } from '../../i18n/t';
const lang = getLang(Astro.url);
const t = useT(lang);
---
<Layout title={`${t.nav.leistungen} · Backroom Physio Berlin`} description={t.leistungen.heroSub} current="/leistungen">
  <PageHero crumb={t.nav.leistungen} eyebrow={t.home.servicesEyebrow} title={t.leistungen.heroTitle} subtitle={t.leistungen.heroSub}
    primary={{ href: cta.book.href, label: t.common.bookDoctolib, external: true }} />

  <section class="py-16 md:py-24 bg-paper">
    <div class="container-px">
      <div class="divide-y divide-line">
        {t.pillars.map((p) => (
          <article id={p.slug} class="grid lg:grid-cols-12 gap-8 lg:gap-12 py-12 md:py-16 scroll-mt-28" data-reveal>
            <div class="lg:col-span-4">
              <span class="icon-chip mb-5"><Icon name={p.icon} size={26} strokeWidth={1.75} /></span>
              <h2 class="display-3 font-display text-ink" style="font-weight:600;">{p.term}</h2>
              <p class="text-muted-light mt-1">{p.sub}</p>
            </div>
            <div class="lg:col-span-8 lg:border-l lg:border-line lg:pl-12">
              {p.long.map((para) => (<p class="text-[1.05rem] leading-relaxed text-muted mb-4 last:mb-0">{para}</p>))}
              {p.slug === 'return-to-sport' && (
                <a href={localizedPath('return-to-sport', lang)} class="link-arrow mt-6 inline-flex">{t.home.rtsLink}<Icon name="ArrowRight" size={15} strokeWidth={2.2} /></a>
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 rounded-[20px] border border-line p-7 md:p-8 flex flex-col sm:flex-row sm:items-center gap-5" style="background: rgb(var(--rgb-surface));" data-reveal>
        <span class="icon-chip flex-none"><Icon name="Info" size={22} strokeWidth={1.8} /></span>
        <p class="text-muted leading-relaxed flex-1">{t.leistungen.note}</p>
        <a href={cta.book.href} target="_blank" rel="noopener" class="btn btn-primary flex-none">{t.common.book}<Icon name="ArrowUpRight" size={16} strokeWidth={2.2} /></a>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
