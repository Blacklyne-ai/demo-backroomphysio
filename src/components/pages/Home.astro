---
import Layout from '../../layouts/Layout.astro';
import Icon from '../Icon.astro';
import SectionHeading from '../SectionHeading.astro';
import MapBlock from '../MapBlock.astro';
import CtaBand from '../CtaBand.astro';
import ReviewsSection from '../ReviewsSection.astro';
import ReviewBadge from '../ReviewBadge.astro';
import { site, cta, addressOneLine } from '../../data/site';
import { getLang } from '../../i18n/ui';
import { useT } from '../../i18n/t';

const lang = getLang(Astro.url);
const t = useT(lang);
const h = t.home;
const gallery = [
  { src: '/images/raum3', alt: 'Kraftgeräte im Trainingsraum' },
  { src: '/images/raum4', alt: 'Trainingsraum mit Fensterfront' },
  { src: '/images/aussen', alt: 'Eingang Backroom Physio, Linienstraße' },
  { src: '/images/raum', alt: 'Trainingsbereich' },
];
const initials = (n: string) => n.split(' ').map((w) => w[0]).join('').slice(0, 2);
const metaTitle = lang === 'de'
  ? site.metaTitle
  : 'Backroom Physio Berlin - Physiotherapy & Return to Sport in Berlin-Mitte';
---
<Layout title={metaTitle} description={h.heroSub} ogImage="/images/og.jpg"
  heroPreload={{ srcset: '/images/raum2-sm.webp 640w, /images/raum2.webp 974w', sizes: '(min-width:1024px) 45vw, 90vw' }}>
  <!-- HERO (hell, Glas, echtes Foto) -->
  <section class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="container-px relative">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="eyebrow mb-6">{h.heroEyebrow}</span>
          <h1 class="display-1 text-balance" set:html={h.heroH1} />
          <p class="lede mt-6 max-w-lg">{h.heroSub}</p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href={cta.book.href} target="_blank" rel="noopener" class="btn btn-primary btn-lg">{t.common.bookDoctolib}<Icon name="ArrowUpRight" size={18} strokeWidth={2.2} /></a>
            <a href={cta.phone.href} class="btn btn-ghost btn-lg"><Icon name="Phone" size={17} strokeWidth={2.2} />{cta.phone.label}</a>
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-2 text-muted-light text-sm">
            {t.pillars.map((p, i) => (<>{i > 0 && <span class="text-green-deep/60" aria-hidden="true">/</span>}<span class="font-display font-bold tracking-wide text-ink-soft">{p.term}</span></>))}
          </div>
          <div class="mt-7"><ReviewBadge variant="light" /></div>
        </div>
        <div class="relative">
          <div class="glass-panel p-3 md:p-4" style="box-shadow: var(--shadow-photo);">
            <div class="relative overflow-hidden rounded-[20px] aspect-[4/5] bg-mist">
              <img src="/images/raum2.webp" srcset="/images/raum2-sm.webp 640w, /images/raum2.webp 974w" sizes="(min-width:1024px) 45vw, 90vw"
                alt="Trainingsraum von Backroom Physio in Berlin-Mitte" width="974" height="1534" fetchpriority="high" decoding="async" class="w-full h-full object-cover" />
              <span class="absolute bottom-4 left-4 tag"><span class="dot"></span>{h.room}</span>
            </div>
          </div>
          <div class="hidden md:block absolute -z-10 -top-6 -right-6 w-40 h-40 rounded-full" style="background: radial-gradient(circle, rgb(31 199 119 / 0.25), transparent 70%);" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN -->
  <section id="leistungen" class="py-16 md:py-24 scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={h.servicesEyebrow} title={h.servicesTitle} intro={h.servicesIntro} />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 mt-12">
        {t.pillars.map((p, i) => (
          <div class="card p-7 md:p-8 flex flex-col" data-reveal style={`--rd:${i * 90}ms`}>
            <span class="icon-chip mb-6"><Icon name={p.icon} size={24} strokeWidth={1.75} /></span>
            <span class="block font-display text-xl md:text-2xl font-bold text-ink leading-tight">{p.term}</span>
            <span class="block text-muted-light text-sm mt-1 mb-3">{p.sub}</span>
            <p class="text-[0.97rem] leading-relaxed text-muted flex-1">{p.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RETURN TO SPORT (hell) -->
  <section class="py-16 md:py-24">
    <div class="container-px">
      <div class="rounded-[28px] overflow-hidden border border-line glass-tint">
        <div class="grid lg:grid-cols-2 gap-0 items-stretch">
          <div class="p-8 md:p-12 lg:p-14 flex flex-col justify-center" data-reveal>
            <span class="eyebrow mb-6">{h.rtsEyebrow}</span>
            <h2 class="display-2 text-balance mb-6">{h.rtsTitle}</h2>
            <p class="text-muted text-lg leading-relaxed mb-4">{h.rtsP1}</p>
            <p class="text-muted text-lg leading-relaxed mb-8">{h.rtsP2}</p>
            <div class="grid sm:grid-cols-3 gap-3">
              {t.rtsPhases.map((ph) => (
                <div class="rounded-2xl p-4 bg-white/55 border border-white/70">
                  <span class="font-display text-green-ink text-xs font-bold tracking-widest">{ph.step}</span>
                  <h3 class="font-display text-ink text-[0.98rem] font-bold mt-1.5">{ph.title}</h3>
                </div>
              ))}
            </div>
          </div>
          <div class="relative min-h-[340px] lg:min-h-full" data-reveal style="--rd:120ms">
            <img src="/images/return-to-sport.webp" alt="Athlet mit Sportprothese beim Lauftraining" width="720" height="900" loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-16 md:py-24 scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={t.team.eyebrow} title={t.team.title} intro={t.team.intro} />

      {/* Featured: Gründer */}
      {t.team.members.slice(0, 1).map((m) => (
        <div class="card p-6 md:p-8 flex flex-col sm:flex-row gap-6 md:gap-8 mt-12" data-reveal>
          <div class="flex-none text-center">
            {m.photo
              ? <img src={m.photo} alt={m.name} width="200" height="200" loading="lazy" class="w-28 h-28 md:w-32 md:h-32 rounded-2xl object-cover" />
              : <span class="relative inline-flex items-center justify-center w-28 h-28 md:w-32 md:h-32 rounded-2xl font-display font-extrabold text-3xl text-white" style="background: rgb(var(--rgb-dark));">{initials(m.name)}<span class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full border-2 border-white inline-flex items-center justify-center" style="background: rgb(var(--rgb-green-deep));"><Icon name="Check" size={15} strokeWidth={3} class="text-white" /></span></span>}
            {!m.photo && <span class="block mt-2 text-[0.64rem] text-muted-light uppercase tracking-wider">{t.team.photoNote}</span>}
          </div>
          <div class="flex-1">
            <h3 class="font-display text-2xl font-bold text-ink">{m.name}</h3>
            <p class="text-green-ink font-semibold text-sm mt-1 mb-3">{m.role}</p>
            <p class="text-muted leading-relaxed">{m.note}</p>
            <div class="flex flex-wrap gap-2 mt-4">{t.about.founderTags.map((tag) => (<span class="tag text-xs">{tag}</span>))}</div>
          </div>
        </div>
      ))}

      {/* Restliches Team */}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5 mt-4 md:mt-5">
        {t.team.members.slice(1).map((m, i) => (
          <div class="card p-5 md:p-6 flex flex-col" data-reveal style={`--rd:${i * 80}ms`}>
            {m.photo
              ? <img src={m.photo} alt={m.name} width="140" height="140" loading="lazy" class="w-16 h-16 rounded-full object-cover" />
              : (
                <span class="inline-flex items-center justify-center w-16 h-16 rounded-full font-display font-extrabold text-xl text-white flex-none" style="background: rgb(var(--rgb-dark));">
                  {m.icon ? <Icon name={m.icon} size={26} strokeWidth={1.9} class="text-green-bright" /> : initials(m.name)}
                </span>
              )}
            <h3 class="font-display text-lg font-bold text-ink mt-4">{m.name}</h3>
            <p class="text-green-ink font-semibold text-[0.8rem] mt-0.5 leading-snug">{m.role}</p>
            {m.note && <p class="text-muted text-[0.9rem] leading-relaxed mt-2">{m.note}</p>}
            {!m.photo && !m.icon && <span class="text-[0.62rem] text-muted-light uppercase tracking-wider mt-3">{t.team.photoNote}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRAXIS + GALERIE -->
  <section id="praxis" class="py-16 md:py-24 scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={h.praxisEyebrow} title={h.praxisTitle} intro={h.praxisLede} />
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mt-12">
        {gallery.map((g) => (
          <div class="relative overflow-hidden rounded-[20px] border border-white/60 group aspect-[4/5]" style="box-shadow: var(--shadow-soft); background: rgb(var(--rgb-mist));">
            <img src={`${g.src}.webp`} srcset={`${g.src}-sm.webp 640w, ${g.src}.webp 1080w`} sizes="(min-width:1024px) 24vw, 50vw" alt={g.alt} width="1080" height="1350" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
        ))}
      </div>
      <p class="text-muted leading-relaxed mt-8 max-w-2xl">{h.praxisP}</p>
    </div>
  </section>

  <ReviewsSection />

  <!-- KONTAKT -->
  <section id="kontakt" class="py-16 md:py-24 scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={h.kontaktEyebrow} title={h.kontaktTitle} intro={h.kontaktIntro} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12">
        <a href={cta.book.href} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3 group sm:col-span-2 lg:col-span-1">
          <span class="icon-chip"><Icon name="CalendarCheck" size={22} strokeWidth={1.8} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Doctolib</span><span class="block font-display text-base font-bold text-ink mt-0.5">{h.tileDoctolib}</span></span>
        </a>
        <a href={cta.phone.href} class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><Icon name="Phone" size={21} strokeWidth={1.9} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{h.tilePhone}</span><span class="block font-display text-base font-bold text-ink mt-0.5">{site.phoneDisplay}</span></span>
        </a>
        <a href={`mailto:${site.email}`} class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><Icon name="Mail" size={21} strokeWidth={1.9} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{h.tileMail}</span><span class="block font-display text-[0.92rem] font-bold text-ink mt-0.5 break-all">{site.email}</span></span>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Instagram</span><span class="block font-display text-base font-bold text-ink mt-0.5">{site.instagramHandle}</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ANFAHRT / GOOGLE MAPS -->
  <section class="pb-16 md:pb-24">
    <div class="container-px">
      <div class="flex items-end justify-between gap-6 mb-6 flex-wrap">
        <div>
          <span class="eyebrow mb-4">{t.maps.eyebrow}</span>
          <h2 class="display-3 font-display mt-1" style="font-weight:800;">{t.maps.title}</h2>
          <p class="text-muted mt-2">{t.maps.text}</p>
        </div>
        <a href={site.maps.url} target="_blank" rel="noopener" class="btn btn-ghost"><Icon name="Navigation" size={16} strokeWidth={2.2} />{t.map.directionsBtn}</a>
      </div>
      <MapBlock class="min-h-[420px]" />
    </div>
  </section>

  <CtaBand />
</Layout>
