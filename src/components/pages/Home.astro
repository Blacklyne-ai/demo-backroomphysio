---
import Layout from '../../layouts/Layout.astro';
import Icon from '../Icon.astro';
import SectionHeading from '../SectionHeading.astro';
import MapBlock from '../MapBlock.astro';
import CtaBand from '../CtaBand.astro';
import ReviewsSection from '../ReviewsSection.astro';
import ReviewBadge from '../ReviewBadge.astro';
import { site, cta, addressOneLine } from '../../data/site';
import { getLang } from '../../i18n/ui';
import { useT } from '../../i18n/t';

const lang = getLang(Astro.url);
const t = useT(lang);
const h = t.home;
const gallery = [
  { src: '/images/raum2', alt: 'Trainingsraum mit Hexagon-Licht' },
  { src: '/images/raum3', alt: 'Kraftgeräte im Trainingsraum' },
  { src: '/images/raum4', alt: 'Trainingsraum mit Fensterfront' },
  { src: '/images/aussen', alt: 'Eingang Backroom Physio, Linienstraße' },
];
const initials = (n: string) => n.split(' ').map((w) => w[0]).join('').slice(0, 2);
const metaTitle = lang === 'de'
  ? site.metaTitle
  : 'Backroom Physio Berlin - Physiotherapy & Return to Sport in Berlin-Mitte';
---
<Layout title={metaTitle} description={h.heroSub} ogImage="/images/og.jpg"
  heroPreload={{ srcset: '/images/hero-sm.webp 1000w, /images/hero.webp 2000w', sizes: '100vw' }}>
  <!-- HERO -->
  <section class="relative min-h-[88svh] flex items-end section-dark overflow-hidden">
    <img src="/images/hero.webp" srcset="/images/hero-sm.webp 1000w, /images/hero.webp 2000w" sizes="100vw"
      alt="Läufer in Bewegung im Dunkeln - Return to Sport" width="2000" height="1334"
      fetchpriority="high" decoding="async" class="absolute inset-0 w-full h-full object-cover" style="object-position: 62% center;" />
    <div class="absolute inset-0" style="background: linear-gradient(105deg, rgb(8 10 12 / 0.92) 28%, rgb(8 10 12 / 0.55) 65%, rgb(8 10 12 / 0.35));" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-40" style="background: linear-gradient(to top, rgb(8 10 12 / 0.9), transparent);" aria-hidden="true"></div>
    <div class="container-px relative w-full pt-32 pb-16 md:pb-24">
      <div class="max-w-3xl">
        <span class="eyebrow eyebrow-on-dark mb-6">{h.heroEyebrow}</span>
        <h1 class="display-1 text-white text-balance" style="text-shadow: 0 2px 30px rgb(0 0 0 / 0.4);" set:html={h.heroH1} />
        <p class="mt-6 text-lg md:text-xl text-white/80 leading-relaxed max-w-xl" style="text-shadow: 0 1px 12px rgb(0 0 0 / 0.5);">{h.heroSub}</p>
        <div class="mt-9 flex flex-col sm:flex-row gap-3">
          <a href={cta.book.href} target="_blank" rel="noopener" class="btn btn-primary btn-lg">{t.common.bookDoctolib}<Icon name="ArrowUpRight" size={18} strokeWidth={2.2} /></a>
          <a href={cta.phone.href} class="btn btn-ghost-dark btn-lg"><Icon name="Phone" size={17} strokeWidth={2.2} />{cta.phone.label}</a>
        </div>
        <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-2 text-white/55 text-sm">
          {t.pillars.map((p, i) => (<>{i > 0 && <span class="text-green/70" aria-hidden="true">/</span>}<span class="font-display tracking-wide">{p.term}</span></>))}
        </div>
        <div class="mt-7"><ReviewBadge variant="glass" /></div>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN -->
  <section id="leistungen" class="py-20 md:py-28 bg-paper scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={h.servicesEyebrow} title={h.servicesTitle} intro={h.servicesIntro} />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 mt-12">
        {t.pillars.map((p, i) => (
          <div class="card p-7 md:p-8 flex flex-col" data-reveal style={`--rd:${i * 90}ms`}>
            <span class="icon-chip mb-6"><Icon name={p.icon} size={24} strokeWidth={1.75} /></span>
            <span class="block font-display text-xl md:text-2xl font-bold text-ink leading-tight">{p.term}</span>
            <span class="block text-muted-light text-sm mt-1 mb-3">{p.sub}</span>
            <p class="text-[0.97rem] leading-relaxed text-muted flex-1">{p.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RETURN TO SPORT -->
  <section class="section-dark glow-green relative overflow-hidden py-20 md:py-28">
    <div class="container-px relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div data-reveal>
          <span class="eyebrow eyebrow-on-dark mb-6">{h.rtsEyebrow}</span>
          <h2 class="display-2 text-white text-balance mb-6">{h.rtsTitle}</h2>
          <p class="text-white/72 text-lg leading-relaxed mb-4">{h.rtsP1}</p>
          <p class="text-white/72 text-lg leading-relaxed">{h.rtsP2}</p>
        </div>
        <div data-reveal style="--rd:120ms">
          <div class="relative overflow-hidden rounded-[22px] border border-white/10 aspect-[4/5] lg:min-h-[460px]" style="box-shadow: var(--shadow-photo); background: rgb(var(--rgb-dark-soft));">
            <img src="/images/return-to-sport.webp" alt="Athlet mit Sportprothese beim Lauftraining" width="720" height="900" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-14">
        {t.rtsPhases.map((ph, i) => (
          <div class="card-dark p-7" data-reveal style={`--rd:${i * 90}ms`}>
            <span class="font-display text-green-bright text-sm font-bold tracking-widest">{ph.step}</span>
            <h3 class="font-display text-white text-xl font-bold mt-3 mb-2.5">{ph.title}</h3>
            <p class="text-white/65 text-[0.95rem] leading-relaxed">{ph.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-20 md:py-28 bg-paper scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={t.team.eyebrow} title={t.team.title} intro={t.team.intro} />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 mt-12">
        {t.team.members.map((m, i) => (
          <div class="card p-7 md:p-8 flex flex-col sm:flex-row gap-6" data-reveal style={`--rd:${i * 90}ms`}>
            <div class="flex-none">
              <span class="relative inline-flex items-center justify-center w-20 h-20 rounded-full font-display font-extrabold text-2xl text-white" style="background: rgb(var(--rgb-dark));">
                {initials(m.name)}
                <span class="absolute -bottom-1 -right-1 w-7 h-7 rounded-full border-2 border-paper inline-flex items-center justify-center" style="background: rgb(var(--rgb-green-deep));"><Icon name="Check" size={13} strokeWidth={3} class="text-white" /></span>
              </span>
              <span class="block mt-2 text-[0.68rem] text-muted-light text-center uppercase tracking-wider">{t.team.photoNote}</span>
            </div>
            <div class="flex-1">
              <h3 class="font-display text-xl font-bold text-ink">{m.name}</h3>
              <p class="text-green-ink font-semibold text-sm mt-0.5 mb-3">{m.role}</p>
              <p class="text-muted leading-relaxed text-[0.96rem]">{m.note}</p>
              {i === 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {t.about.founderTags.map((tag) => (<span class="tag text-xs">{tag}</span>))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRAXIS -->
  <section id="praxis" class="py-20 md:py-28 scroll-mt-24" style="background: rgb(var(--rgb-surface));">
    <div class="container-px">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center mb-12">
        <div data-reveal>
          <span class="eyebrow mb-5">{h.praxisEyebrow}</span>
          <h2 class="display-2 text-balance mb-6">{h.praxisTitle}</h2>
          <p class="lede mb-4">{h.praxisLede}</p>
          <p class="text-muted leading-relaxed">{h.praxisP}</p>
        </div>
        <div data-reveal style="--rd:120ms">
          <div class="relative overflow-hidden rounded-[22px] border border-line aspect-[5/4] lg:min-h-[380px]" style="box-shadow: var(--shadow-photo); background: rgb(var(--rgb-mist));">
            <img src="/images/raum2.webp" srcset="/images/raum2-sm.webp 640w, /images/raum2.webp 974w" sizes="(min-width:1024px) 45vw, 90vw" alt="Trainingsraum von Backroom Physio in Berlin-Mitte" width="974" height="1534" loading="lazy" class="w-full h-full object-cover" />
            <span class="absolute bottom-4 left-4 tag tag-dark"><span class="dot"></span>{h.room}</span>
          </div>
        </div>
      </div>
      <p class="eyebrow mb-5">{t.praxisGallery}</p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4" data-reveal>
        {gallery.map((g) => (
          <div class="relative overflow-hidden rounded-2xl border border-line aspect-square" style="background: rgb(var(--rgb-mist));">
            <img src={`${g.src}.webp`} srcset={`${g.src}-sm.webp 640w, ${g.src}.webp 1080w`} sizes="(min-width:1024px) 22vw, 45vw" alt={g.alt} width="1080" height="1080" loading="lazy" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <ReviewsSection />

  <!-- KONTAKT -->
  <section id="kontakt" class="py-20 md:py-28 bg-paper scroll-mt-24">
    <div class="container-px">
      <SectionHeading eyebrow={h.kontaktEyebrow} title={h.kontaktTitle} intro={h.kontaktIntro} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12">
        <a href={cta.book.href} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3 group sm:col-span-2 lg:col-span-1">
          <span class="icon-chip"><Icon name="CalendarCheck" size={22} strokeWidth={1.8} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Doctolib</span><span class="block font-display text-base font-bold text-ink mt-0.5">{h.tileDoctolib}</span></span>
        </a>
        <a href={cta.phone.href} class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><Icon name="Phone" size={21} strokeWidth={1.9} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{h.tilePhone}</span><span class="block font-display text-base font-bold text-ink mt-0.5">{site.phoneDisplay}</span></span>
        </a>
        <a href={`mailto:${site.email}`} class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><Icon name="Mail" size={21} strokeWidth={1.9} /></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">{h.tileMail}</span><span class="block font-display text-[0.92rem] font-bold text-ink mt-0.5 break-all">{site.email}</span></span>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener" class="card card-hover p-6 flex flex-col gap-3">
          <span class="icon-chip"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></span>
          <span><span class="block text-muted-light text-xs uppercase tracking-wider font-display">Instagram</span><span class="block font-display text-base font-bold text-ink mt-0.5">{site.instagramHandle}</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ANFAHRT / GOOGLE MAPS (unten) -->
  <section class="pb-20 md:pb-28 bg-paper">
    <div class="container-px">
      <div class="flex items-end justify-between gap-6 mb-6 flex-wrap">
        <div>
          <span class="eyebrow mb-4">{t.maps.eyebrow}</span>
          <h2 class="display-3 font-display mt-1" style="font-weight:800;">{t.maps.title}</h2>
          <p class="text-muted mt-2">{t.maps.text}</p>
        </div>
        <a href={site.maps.url} target="_blank" rel="noopener" class="btn btn-ghost"><Icon name="Navigation" size={16} strokeWidth={2.2} />{t.map.directionsBtn}</a>
      </div>
      <MapBlock class="min-h-[420px]" />
    </div>
  </section>

  <CtaBand />
</Layout>
