---
// Fonts sind self-hosted in global.css (@font-face, font-display:optional → CLS ~0).
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[] | null;
  heroPreload?: { srcset: string; sizes?: string };
}
const {
  title,
  description = site.metaDescription,
  current = '',
  ogImage = '/images/og.jpg',
  noindex = false,
  schema = null,
  heroPreload,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <!-- LCP-Fonts: Display (Hero-Headline) + Body -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />
    {heroPreload && <link rel="preload" as="image" type="image/webp" imagesrcset={heroPreload.srcset} imagesizes={heroPreload.sizes ?? '100vw'} fetchpriority="high" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow" />}
    <meta name="theme-color" content="#111417" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content={ogImageUrl} />

    <SchemaOrg schema={schema} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCTA />
    <CookieBanner />

    <script>
      // Scroll-Reveal — Emil-Kowalski-Stil: ruhige Feder + Blur-In, Stagger via inline --rd.
      // Motion (motion.dev, vanilla) — wird von Astro/Vite ins statische Bundle gebaut.
      import { inView, animate } from 'motion';

      function revealOne(el) {
        if (el.dataset.revealDone) return;   // idempotent (Sofort-Lauf + astro:page-load)
        el.dataset.revealDone = '1';
        const rd = parseFloat(getComputedStyle(el).getPropertyValue('--rd')) || 0; // "90ms" -> 90
        const delay = rd / 1000;
        const isHero = el.getAttribute('data-reveal') === 'hero'; // LCP-safe: nur Transform, kein Fade
        inView(el, () => {
          animate(
            el,
            isHero
              ? { y: [12, 0] }
              : { opacity: [0, 1], y: [12, 0], filter: ['blur(6px)', 'blur(0px)'] },
            { type: 'spring', stiffness: 190, damping: 25, delay }
          );
        }, { amount: 0.15, margin: '0px 0px -40px 0px' });
      }

      function initReveal() {
        const els = document.querySelectorAll('[data-reveal]');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((e) => { e.style.opacity = '1'; e.style.transform = 'none'; e.style.filter = 'none'; });
          return;
        }
        els.forEach(revealOne);
      }

      // Sofort starten (Motion-Modul lädt evtl. NACH dem ersten astro:page-load) + bei jeder SPA-Navigation.
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <style is:global>
      .skip-link { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
      .skip-link:focus { position: fixed; top: 1rem; left: 1rem; width: auto; height: auto; clip: auto; padding: 0.75rem 1.25rem; background: #0B7D46; color: #fff; border-radius: 999px; z-index: 100; font-weight: 600; }
    </style>
  </body>
</html>
